{
  "openapi": "3.1.0",
  "info": {
    "title": "Gavelogy Private Admin API",
    "version": "1.0.0",
    "description": "Allowlisted private admin API for GPT/MCP automation. Supports only create/read/update/publish workflows. Deletion remains manual in Gavelogy admin UI."
  },
  "servers": [
    {
      "url": "https://<my-vercel-domain>"
    }
  ],
  "security": [
    {
      "AdminSecret": []
    }
  ],
  "components": {
    "securitySchemes": {
      "AdminSecret": {
        "type": "apiKey",
        "in": "header",
        "name": "x-admin-secret"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "CourseCreate": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "is_active": {
            "type": "boolean"
          },
          "is_free": {
            "type": "boolean"
          },
          "icon": {
            "type": "string"
          }
        }
      },
      "CoursePatch": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "is_active": {
            "type": "boolean"
          },
          "is_free": {
            "type": "boolean"
          },
          "icon": {
            "type": "string"
          }
        }
      },
      "StructureItemCreate": {
        "type": "object",
        "required": [
          "title",
          "item_type"
        ],
        "properties": {
          "parentId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "item_type": {
            "type": "string",
            "enum": [
              "folder",
              "file"
            ]
          },
          "order_index": {
            "type": "number"
          },
          "icon": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          },
          "pdf_url": {
            "type": "string"
          }
        }
      },
      "StructureItemPatch": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "parentId": {
            "type": [
              "string",
              "null"
            ]
          },
          "order_index": {
            "type": "number"
          },
          "icon": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          },
          "pdf_url": {
            "type": "string"
          },
          "item_type": {
            "type": "string",
            "enum": [
              "folder",
              "file"
            ]
          }
        }
      },
      "Flashcard": {
        "type": "object",
        "required": [
          "front",
          "back"
        ],
        "properties": {
          "front": {
            "type": "string"
          },
          "back": {
            "type": "string"
          }
        }
      },
      "QuizQuestion": {
        "type": "object",
        "required": [
          "questionText",
          "options",
          "correctAnswer"
        ],
        "properties": {
          "questionText": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 4,
            "maxItems": 4
          },
          "correctAnswer": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/api/mcp/admin/capabilities": {
      "get": {
        "operationId": "getAdminCapabilities",
        "summary": "Get allowed and forbidden operations",
        "responses": {
          "200": {
            "description": "Capabilities"
          }
        }
      }
    },
    "/api/mcp/admin/standalone-quizzes": {
      "get": {
        "operationId": "listStandaloneQuizzes",
        "summary": "List standalone quizzes",
        "responses": {
          "200": {
            "description": "Standalone quiz list"
          }
        }
      },
      "post": {
        "operationId": "createStandaloneQuiz",
        "summary": "Create standalone quiz",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "subject_id": {
                    "type": "string"
                  },
                  "order_index": {
                    "type": "number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Standalone quiz created"
          }
        }
      }
    },
    "/api/mcp/admin/standalone-quizzes/{quizId}": {
      "patch": {
        "operationId": "updateStandaloneQuiz",
        "summary": "Update standalone quiz",
        "parameters": [
          {
            "name": "quizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Standalone quiz updated"
          }
        }
      }
    },
    "/api/mcp/admin/standalone-quizzes/{quizId}/questions": {
      "get": {
        "operationId": "listStandaloneQuizQuestions",
        "summary": "List standalone quiz questions",
        "parameters": [
          {
            "name": "quizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Standalone questions"
          }
        }
      },
      "post": {
        "operationId": "createStandaloneQuizQuestion",
        "summary": "Create standalone quiz question",
        "parameters": [
          {
            "name": "quizId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "question_text",
                  "correct_answer"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Standalone question created"
          }
        }
      }
    },
    "/api/mcp/admin/standalone-questions/{questionId}": {
      "patch": {
        "operationId": "updateStandaloneQuestion",
        "summary": "Update standalone question",
        "parameters": [
          {
            "name": "questionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Standalone question updated"
          }
        }
      }
    },
    "/api/mcp/admin/pyq-tests": {
      "get": {
        "operationId": "listPyqTests",
        "summary": "List PYQ tests",
        "responses": {
          "200": {
            "description": "PYQ tests"
          }
        }
      },
      "post": {
        "operationId": "createPyqTest",
        "summary": "Create PYQ test",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "PYQ test created"
          }
        }
      }
    },
    "/api/mcp/admin/pyq-tests/{testId}": {
      "patch": {
        "operationId": "updatePyqTest",
        "summary": "Update PYQ test",
        "parameters": [
          {
            "name": "testId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PYQ test updated"
          }
        }
      }
    },
    "/api/mcp/admin/pyq-tests/{testId}/passages": {
      "get": {
        "operationId": "listPyqPassages",
        "summary": "List PYQ passages",
        "parameters": [
          {
            "name": "testId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PYQ passages"
          }
        }
      },
      "post": {
        "operationId": "createPyqPassage",
        "summary": "Create PYQ passage",
        "parameters": [
          {
            "name": "testId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "passage_text"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "PYQ passage created"
          }
        }
      }
    },
    "/api/mcp/admin/pyq-passages/{passageId}": {
      "patch": {
        "operationId": "updatePyqPassage",
        "summary": "Update PYQ passage",
        "parameters": [
          {
            "name": "passageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PYQ passage updated"
          }
        }
      }
    },
    "/api/mcp/admin/pyq-tests/{testId}/questions": {
      "get": {
        "operationId": "listPyqQuestions",
        "summary": "List PYQ questions",
        "parameters": [
          {
            "name": "testId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PYQ questions"
          }
        }
      },
      "post": {
        "operationId": "createPyqQuestion",
        "summary": "Create PYQ question",
        "parameters": [
          {
            "name": "testId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "question_text"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "PYQ question created"
          }
        }
      }
    },
    "/api/mcp/admin/pyq-questions/{questionId}": {
      "patch": {
        "operationId": "updatePyqQuestion",
        "summary": "Update PYQ question",
        "parameters": [
          {
            "name": "questionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PYQ question updated"
          }
        }
      }
    }
  }
}